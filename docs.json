{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Facturear — Facturación Electrónica Argentina",
  "description": "Facturear es la plataforma de facturación electrónica más simple de Argentina. Emitá facturas con CAE de ARCA/AFIP vía API o dashboard, sin complicaciones.",
  "colors": {
    "primary": "#4f46e5",
    "light": "#6366f1",
    "dark": "#4338ca"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guías",
        "groups": [
          {
            "group": "Inicio",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Comenzar",
            "pages": [
              "es/getting-started/index"
            ]
          },
          {
            "group": "Configuración",
            "pages": [
              "es/guides/certificado-digital",
              "es/guides/delegacion",
              "es/guides/primera-factura",
              "es/guides/facturacion-lotes"
            ]
          },
          {
            "group": "Fundamentos",
            "pages": [
              "es/fundamentos/que-es-factura-electronica",
              "es/fundamentos/tipos-de-comprobantes",
              "es/fundamentos/monotributo",
              "es/fundamentos/responsable-inscripto"
            ]
          }
        ]
      },
      {
        "tab": "Novedades",
        "groups": [
          {
            "group": "Novedades Impositivas",
            "pages": [
              "es/novedades/declaracion-jurada-ganancias-2026-paso-a-paso-2026-05-03",
              "es/novedades/monotributo-mayo-2026-cuanto-pagar-2026-05-03",
              "es/novedades/arca-reemplaza-afip",
              "es/novedades/factura-credito-electronica-mipymes",
              "es/novedades/obligatoriedad-factura-electronica"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "es/api-reference/index",
              "es/api-reference/playground"
            ]
          },
          {
            "group": "API Endpoints",
            "openapi": "openapi.json"
          }
        ]
      }
    ]
  },
  "global": {
    "anchors": [
      {
        "anchor": "GitHub",
        "href": "https://github.com/estoussel/facturear",
        "icon": "github"
      },
      {
        "anchor": "Support",
        "href": "mailto:support@facture.ar",
        "icon": "life-ring"
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@facture.ar"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://facture.ar"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": [
        "curl",
        "javascript",
        "python",
        "php"
      ],
      "defaults": "required"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/estoussel/facturear"
    }
  },
  "appearance": {
    "default": "light",
    "strict": true
  }
}
